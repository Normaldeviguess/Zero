$mainMod = SUPER

# Core Binds
bind = $mainMod, Q, exec, kitty
bind = $mainMod, X, killactive,
bind = $mainMod, SPACE, exec, wofi --show drun
bind = $mainMod, M, exit, 

# Input Fix
input {
    kb_layout = us
    follow_mouse = 1
    touchpad {
        tap-to-click = true
    }
}

general {
    gaps_in = 5
    gaps_out = 20
    border_size = 2
    col.active_border = rgba(33ccffee)
    col.inactive_border = rgba(595959aa)
}
bind = , mouse:274, killactive,
